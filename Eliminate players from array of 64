import numpy as np
from manim import *
import itertools
import random
import math

config.pixel_height = 1920
config.pixel_width = 1080
config.frame_height = 16.0
config.frame_width = 9.0

class PigeonHole(MovingCameraScene):
    def construct(self):
        self.camera.background_color = "#121414"

        men = VGroup(*[SVGMobject("man svg.svg").set_fill(WHITE).scale(0.3) for _ in range(64)])
        men.arrange_in_grid(rows=4, cols=16, buff=0.2)
        men.shift(UP * 1) 
        
        self.add(men)
        

        matches_tracker = ValueTracker(0)
        

        counter_label = Text("Number of matches played: ").scale(0.8)
        

        counter_number = always_redraw(
            lambda: Integer(matches_tracker.get_value()).scale(1.1)
            .next_to(counter_label, RIGHT)
        )
        
        counter_group = VGroup(counter_label, counter_number).to_edge(DOWN, buff=4)
        
        self.add(counter_label, counter_number)
        self.wait(1)

        active_players = list(men)

        for _ in range(6):
            num_to_eliminate = len(active_players) // 2
            eliminated_players = random.sample(active_players, k=num_to_eliminate)
            elims_group = VGroup(*eliminated_players)
            
            new_total = matches_tracker.get_value() + num_to_eliminate
            
            self.play(
                FadeOut(elims_group),
                matches_tracker.animate.set_value(new_total),
                run_time=1
            )
            
            active_players = [p for p in active_players if p not in eliminated_players]
            self.wait(0.5)
            
        winner = active_players[0]
        self.play(winner.animate.set_color(YELLOW))
        self.wait(2)
        
